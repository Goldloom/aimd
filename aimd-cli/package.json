{
  "name": "aimd-cli",
  "version": "0.1.0",
  "description": "CLI parser for AIMD (AI-Enhanced Markdown) — build, token count, convert",
  "type": "module",
  "bin": {
    "aimd": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["aimd", "markdown", "ai", "cli", "token"],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.15",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2"
  }
}
