{
  "name": "AIMD",
  "scopeName": "text.aimd",
  "fileTypes": ["aimd"],
  "patterns": [
    { "include": "#frontMatter" },
    { "include": "#stateBlock" },
    { "include": "#humanBlock" },
    { "include": "#schemaBlock" },
    { "include": "#apiBlock" },
    { "include": "#sharedBlock" },
    { "include": "#refAnnotation" },
    { "include": "#markdown" }
  ],
  "repository": {
    "frontMatter": {
      "begin": "^---$",
      "end": "^---$",
      "name": "meta.embedded.block.yaml",
      "contentName": "source.yaml",
      "patterns": [{ "include": "source.yaml" }]
    },
    "stateBlock": {
      "begin": "^(:::state)(.*)$",
      "end": "^(:::)$",
      "name": "meta.block.state.aimd",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.aimd" },
        "2": { "name": "entity.name.section.aimd" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.directive.aimd" }
      },
      "patterns": [
        {
          "match": "^(v\\d+)(:)",
          "captures": {
            "1": { "name": "markup.inserted.aimd" },
            "2": { "name": "punctuation.separator.key-value.aimd" }
          }
        },
        {
          "match": "^(o\\d+|ask\\d+)(:)",
          "captures": {
            "1": { "name": "markup.changed.aimd" },
            "2": { "name": "punctuation.separator.key-value.aimd" }
          }
        },
        {
          "match": "^(a\\d+|n\\d+)(:)",
          "captures": {
            "1": { "name": "markup.italic.aimd" },
            "2": { "name": "punctuation.separator.key-value.aimd" }
          }
        }
      ]
    },
    "humanBlock": {
      "begin": "^(:::human)(.*)$",
      "end": "^(:::)$",
      "name": "comment.block.human.aimd",
      "beginCaptures": {
        "1": { "name": "comment.block.human.aimd" },
        "2": { "name": "comment.block.human.aimd" }
      },
      "endCaptures": {
        "1": { "name": "comment.block.human.aimd" }
      }
    },
    "schemaBlock": {
      "begin": "^(:::schema)(.*)$",
      "end": "^(:::)$",
      "name": "meta.block.schema.aimd",
      "beginCaptures": {
        "1": { "name": "storage.type.class.aimd" },
        "2": { "name": "entity.name.type.class.aimd" }
      },
      "endCaptures": {
        "1": { "name": "storage.type.class.aimd" }
      },
      "patterns": [
        {
          "match": "(@deprecated(?:\\([^)]*\\))?|@since(?:\\([^)]*\\))?)",
          "name": "invalid.deprecated.aimd"
        },
        {
          "match": "(@\\w+(?:\\([^)]*\\))?)",
          "name": "entity.other.attribute-name.aimd"
        },
        {
          "match": "(!|\\?)",
          "name": "keyword.operator.logical.aimd"
        },
        {
          "match": "(#\\w+)",
          "name": "constant.language.aimd"
        }
      ]
    },
    "apiBlock": {
      "begin": "^(:::api)(.*)$",
      "end": "^(:::)$",
      "name": "meta.block.api.aimd",
      "beginCaptures": {
        "1": { "name": "storage.type.function.aimd" },
        "2": { "name": "entity.name.function.aimd" }
      },
      "endCaptures": {
        "1": { "name": "storage.type.function.aimd" }
      },
      "patterns": [
        {
          "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b",
          "name": "keyword.other.http-method.aimd"
        },
        {
          "match": "(@\\w+)(:)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.aimd" },
            "2": { "name": "punctuation.separator.aimd" }
          }
        }
      ]
    },
    "sharedBlock": {
      "begin": "^(:::(?:flow|rules|test|diff|intent|ref))(.*)$",
      "end": "^(:::)$",
      "name": "meta.block.shared.aimd",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.aimd" },
        "2": { "name": "string.unquoted.aimd" }
      },
      "endCaptures": {
        "1": { "name": "keyword.control.directive.aimd" }
      }
    },
    "refAnnotation": {
      "match": "(@ref:[^\\s]+)",
      "name": "markup.underline.link.aimd"
    },
    "markdown": {
      "patterns": [
        {
          "match": "^#{1,6}\\s.+$",
          "name": "markup.heading.markdown"
        },
        {
          "match": "\\*\\*[^*]+\\*\\*",
          "name": "markup.bold.markdown"
        },
        {
          "match": "`[^`]+`",
          "name": "markup.inline.raw.string.markdown"
        }
      ]
    }
  }
}
